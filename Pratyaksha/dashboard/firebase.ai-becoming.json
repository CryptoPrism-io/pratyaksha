{
  "hosting": {
    "site": "ai-becoming",
    "public": "dist",
    "ignore": ["firebase.json", "firebase.ai-becoming.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
